# Do not put Groq browser keys in Vite env for public builds.
# Use public/runtime-config.js locally and keep it out of git.
VITE_AUTH_API_BASE=http://localhost:8787/api
VITE_BILLING_API_BASE=http://localhost:8787/api
VITE_DEVICE_SYNC_API_BASE=http://localhost:8787/api
VITE_ALLOW_BROWSER_GROQ_KEYS=false
VITE_ENABLE_DEMO_OTP=false
VITE_ENABLE_DEMO_BILLING=false
VITE_ENABLE_DEMO_DEVICE_SYNC=false
VITE_ENABLE_TEST_ACCOUNT=false

# Backend server
NODE_ENV=development
PORT=8787
APP_URL=http://localhost:5174
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,capacitor://localhost,http://localhost
SESSION_SECRET=replace_with_a_32_plus_character_random_secret
DATA_ENCRYPTION_SECRET=replace_with_another_32_plus_character_random_secret
MAIL_FROM=MuscleBuilder <no-reply@musclebuilder.app>
RESEND_API_KEY=
ALLOW_CONSOLE_OTP=false

# Web billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# RevenueCat webhooks from native store billing
REVENUECAT_WEBHOOK_SECRET=
