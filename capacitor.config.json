{
  "appId": "com.musclebuilder.app",
  "appName": "MuscleBuilder",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#0A0A0A",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0A0A0A"
    },
    "Haptics": {
      "enabled": true
    },
    "LocalNotifications": {
      "iconColor": "#22C55E"
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  },
  "ios": {
    "contentInset": "automatic",
    "preferredContentMode": "mobile",
    "scheme": "MuscleBuilder",
    "backgroundColor": "#0A0A0A",
    "allowsLinkPreview": false
  }
}
